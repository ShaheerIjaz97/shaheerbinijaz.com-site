---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
---
<Base title="404 — Not found">
  <Nav />
  <main id="main" class="max-w-container mx-auto px-6 lg:px-10 py-32 min-h-[60vh] flex flex-col justify-center">
    <p class="font-mono text-xs text-indigo">404</p>
    <h1 class="mt-4 font-serif text-display-xl text-ink max-w-[18ch]">
      That page does not exist.
    </h1>
    <p class="mt-6 text-ink-700 max-w-prose">
      Likely a stale link from an older version of the site. Head back to the homepage to find what you were looking for.
    </p>
    <a href="/" class="mt-8 btn btn-primary self-start">
      Back to home
      <span aria-hidden="true">→</span>
    </a>
  </main>
  <Footer />
</Base>
