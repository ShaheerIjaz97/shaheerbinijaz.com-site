---
import Base from "../layouts/Base.astro";
import { Icon } from "astro-icon/components";
import {
  profile,
  about,
  experience,
  education,
  stack,
  principles,
} from "../content/site";
---

<Base title="CV — Shaheer Bin Ijaz" description="Senior Software Engineer — Python backends, data pipelines, ML & CV systems.">

  <!-- Print + screen toolbar (hidden when printing) -->
  <div class="no-print sticky top-0 z-30 backdrop-blur bg-canvas/85 border-b border-canvas-rule">
    <div class="max-w-[820px] mx-auto px-5 lg:px-8 h-14 flex items-center justify-between gap-3">
      <a href="/" class="inline-flex items-center gap-2 text-sm text-ink-700 hover:text-violet transition-colors">
        <Icon name="lucide:arrow-left" class="w-4 h-4" />
        Back to portfolio
      </a>
      <div class="flex items-center gap-2">
        <button
          type="button"
          onclick="window.print()"
          class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full text-canvas text-xs font-mono font-bold bg-gradient-to-r from-magenta via-violet to-cyan shadow-md hover:shadow-[0_8px_20px_-6px_rgba(124,58,237,0.55)] hover:-translate-y-0.5 transition-all"
        >
          <Icon name="lucide:printer" class="w-3.5 h-3.5" />
          Save as PDF / Print
        </button>
      </div>
    </div>
  </div>

  <!-- CV body -->
  <main class="cv-page max-w-[820px] mx-auto px-5 lg:px-8 py-10 lg:py-14">

    <!-- Header -->
    <header class="border-b-2 border-ink pb-5">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-3">
        <div>
          <h1 class="font-sans font-extrabold tracking-tight text-3xl lg:text-4xl text-ink leading-[1.05]">
            Shaheer Bin Ijaz
          </h1>
          <p class="mt-1 font-mono text-xs uppercase tracking-[0.18em] text-violet font-bold">
            {profile.title} · {profile.taglinePipes}
          </p>
        </div>
        <div class="text-sm text-ink-700 leading-snug md:text-right">
          <p class="inline-flex items-center gap-1.5"><Icon name="lucide:mail" class="w-3.5 h-3.5 text-magenta" />{profile.email}</p><br />
          <p class="inline-flex items-center gap-1.5"><Icon name="lucide:map-pin" class="w-3.5 h-3.5 text-cyan-deep" />{profile.location}</p><br />
          <p class="inline-flex items-center gap-1.5"><Icon name="lucide:github" class="w-3.5 h-3.5 text-ink" />github.com/ShaheerIjaz97</p><br />
          <p class="inline-flex items-center gap-1.5"><Icon name="lucide:linkedin" class="w-3.5 h-3.5 text-violet" />linkedin.com/in/shaheer-bin-ijaz</p>
        </div>
      </div>
    </header>

    <!-- Summary -->
    <section class="mt-6">
      <h2 class="cv-h2"><span class="cv-bar bg-magenta"></span>Summary</h2>
      <p class="mt-2 text-[13.5px] text-ink-800 leading-relaxed">
        {about.paragraphs[0]}
      </p>
    </section>

    <!-- Experience -->
    <section class="mt-6">
      <h2 class="cv-h2"><span class="cv-bar bg-violet"></span>Experience</h2>
      <ol class="mt-3 space-y-5">
        {experience.items.map((item) => (
          <li>
            <div class="flex flex-wrap items-baseline justify-between gap-x-3">
              <h3 class="font-serif text-lg text-ink leading-tight">
                {item.role} <span class="text-violet font-sans text-base font-semibold">· {item.org}</span>
              </h3>
              <p class="font-mono text-[11px] text-ink-700 whitespace-nowrap">{item.period}</p>
            </div>
            <p class="font-mono text-[10.5px] text-ink-500 mt-0.5">{item.location}</p>
            <ul class="mt-1.5 space-y-1 list-none">
              {item.bullets.slice(0, 4).map((b: string) => (
                <li class="flex gap-2 text-[12.5px] text-ink-800 leading-snug">
                  <span class="text-violet font-bold mt-[1px]">·</span>
                  <span>{b}</span>
                </li>
              ))}
            </ul>
          </li>
        ))}
      </ol>
    </section>

    <!-- Stack -->
    <section class="mt-6">
      <h2 class="cv-h2"><span class="cv-bar bg-cyan"></span>Stack</h2>
      <dl class="mt-2 grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-1.5 text-[12.5px]">
        {stack.groups.map((g) => (
          <div class="flex gap-2">
            <dt class="font-mono text-[11px] text-ink-700 font-semibold uppercase tracking-wide whitespace-nowrap min-w-[110px]">{g.title}:</dt>
            <dd class="text-ink-800">{g.items.join(", ")}</dd>
          </div>
        ))}
      </dl>
    </section>

    <!-- Education -->
    <section class="mt-6">
      <h2 class="cv-h2"><span class="cv-bar bg-lime-deep"></span>Education</h2>
      <ul class="mt-2 space-y-2">
        {education.items.map((item) => (
          <li class="flex flex-wrap items-baseline justify-between gap-x-3">
            <p class="text-[13px] text-ink">
              <span class="font-serif">{item.degree}</span>
              <span class="text-ink-700 text-[12px]"> · {item.org}</span>
            </p>
            <p class="font-mono text-[11px] text-ink-700">{item.period}</p>
          </li>
        ))}
      </ul>
    </section>

    <!-- Principles (compact) -->
    <section class="mt-6 cv-keep-together">
      <h2 class="cv-h2"><span class="cv-bar bg-coral"></span>Engineering principles</h2>
      <ul class="mt-2 grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-1 text-[12.5px]">
        {principles.items.map((p) => (
          <li class="flex gap-2">
            <span class="text-coral font-bold">·</span>
            <span class="text-ink-800"><strong class="text-ink">{p.title.replace(/\.$/, "")}.</strong> <span class="text-ink-700">{p.body.split(". ")[0]}.</span></span>
          </li>
        ))}
      </ul>
    </section>

    <!-- Footer note -->
    <footer class="mt-8 pt-3 border-t border-canvas-rule text-[10.5px] text-ink-500 font-mono">
      Generated from shaheerbinijaz-com-site.pages.dev · Updated {new Date().getFullYear()}
    </footer>

  </main>

</Base>

<style>
  /* CV-specific styling — overrides global mesh / nav / etc. */
  .cv-h2 {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: theme("fontFamily.mono");
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-weight: 700;
    color: theme("colors.ink.700");
  }
  .cv-bar {
    display: inline-block;
    width: 1.5rem;
    height: 3px;
    border-radius: 999px;
  }

  /* Print rules — A4 / Letter friendly */
  @media print {
    @page {
      size: A4;
      margin: 14mm 12mm;
    }
    html, body {
      background: #fff !important;
    }
    .cv-page {
      max-width: none !important;
      padding: 0 !important;
    }
    .cv-keep-together {
      break-inside: avoid;
      page-break-inside: avoid;
    }
    /* Hide the global scroll progress bar in print */
    #scroll-progress { display: none !important; }
  }
</style>
