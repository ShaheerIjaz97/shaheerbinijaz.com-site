---
interface Props {
  number: string;
  label: string;
  heading: string;
  intro?: string;
  accent?: "indigo" | "amber" | "moss" | "magenta" | "cyan" | "violet" | "coral" | "lime";
}
const { number, label, heading, intro, accent = "indigo" } = Astro.props;

const accentClasses: Record<string, { badge: string; rule: string; eyebrow: string }> = {
  indigo:  { badge: "bg-indigo text-canvas",  rule: "bg-gradient-to-r from-indigo to-violet",   eyebrow: "text-indigo" },
  amber:   { badge: "bg-amber text-canvas",   rule: "bg-gradient-to-r from-amber to-coral",    eyebrow: "text-amber-deep" },
  moss:    { badge: "bg-moss text-canvas",    rule: "bg-gradient-to-r from-moss to-lime-deep", eyebrow: "text-moss" },
  magenta: { badge: "bg-magenta text-canvas", rule: "bg-gradient-to-r from-magenta to-coral",  eyebrow: "text-magenta" },
  cyan:    { badge: "bg-cyan text-canvas",    rule: "bg-gradient-to-r from-cyan to-violet",    eyebrow: "text-cyan-deep" },
  violet:  { badge: "bg-violet text-canvas",  rule: "bg-gradient-to-r from-violet to-magenta", eyebrow: "text-violet" },
  coral:   { badge: "bg-coral text-canvas",   rule: "bg-gradient-to-r from-coral to-magenta",  eyebrow: "text-coral-deep" },
  lime:    { badge: "bg-lime-deep text-canvas", rule: "bg-gradient-to-r from-lime-deep to-cyan", eyebrow: "text-lime-deep" },
};
const a = accentClasses[accent];
---
<header class="reveal max-w-container mx-auto px-5 lg:px-10 pt-16 pb-6 lg:pt-28 lg:pb-10">
  <div class="flex items-center gap-3 lg:gap-4">
    <span class={`inline-flex items-center justify-center h-8 lg:h-9 px-2.5 lg:px-3 rounded-full font-mono text-xs lg:text-sm font-extrabold shadow-lg ${a.badge}`}>
      {number}
    </span>
    <span class={`font-mono text-[11px] lg:text-xs uppercase tracking-[0.18em] lg:tracking-[0.20em] font-bold ${a.eyebrow}`}>{label}</span>
    <span class={`hidden md:inline-block h-[4px] w-20 ${a.rule} rounded-full shadow-sm`}></span>
  </div>
  <h2 class="mt-4 lg:mt-5 font-serif text-[2rem] sm:text-[2.5rem] lg:text-display-lg text-ink max-w-[28ch] leading-[1.08] lg:leading-[1.05]">{heading}</h2>
  {intro && <p class="mt-3 lg:mt-4 max-w-prose text-ink-800 leading-relaxed text-sm lg:text-base">{intro}</p>}
  <div class="mt-6 lg:mt-8 hairline"></div>
</header>
