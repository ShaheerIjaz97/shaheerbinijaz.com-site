---
import { work } from "../content/site";
import SectionHeader from "./SectionHeader.astro";
---
<section id="work">
  <SectionHeader number={work.number} label={work.label} heading={work.heading} intro={work.intro} />
  <div class="max-w-container mx-auto px-6 lg:px-10 pb-12 space-y-6">
    {work.items.map((item) => (
      <article class="card rounded-2xl p-6 lg:p-8 reveal grid lg:grid-cols-12 gap-6">
        <div class="lg:col-span-3 flex flex-col gap-1">
          <span class="font-mono text-xs text-ink-400">{item.id}</span>
          <span class="font-mono text-[11px] uppercase tracking-wider text-indigo">{item.kicker}</span>
        </div>
        <div class="lg:col-span-9">
          <h3 class="font-serif text-display-md text-ink leading-tight">{item.title}</h3>
          <p class="mt-3 text-ink-700 leading-relaxed">{item.summary}</p>
          <p class="mt-3 text-sm text-ink-500 leading-relaxed max-w-prose">{item.detail}</p>
          <div class="mt-5 flex flex-wrap gap-2">
            {item.stack.map((s) => (
              <span class="font-mono text-[11px] px-2.5 py-1 rounded-full bg-canvas-deep text-ink-700 border border-canvas-rule">
                {s}
              </span>
            ))}
          </div>
          <div class="mt-5 flex flex-wrap items-center gap-4 text-sm">
            <a href={item.links.repo} class="link inline-flex items-center gap-1.5">
              View repo
              <span aria-hidden="true">↗</span>
            </a>
          </div>
        </div>
      </article>
    ))}
  </div>
  <div class="max-w-container mx-auto px-6 lg:px-10 pb-24 reveal">
    <a href={work.more.href} class="inline-flex items-center gap-2 text-sm text-ink-500 hover:text-ink underline underline-offset-4 decoration-canvas-rule2 hover:decoration-ink">
      {work.more.label}
      <span aria-hidden="true">↗</span>
    </a>
  </div>
</section>
