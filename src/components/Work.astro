---
import { work } from "../content/site";
import SectionHeader from "./SectionHeader.astro";
import { Icon } from "astro-icon/components";

const iconForKicker: Record<string, string> = {
  "Backend · Workflow":      "lucide:git-branch",
  "FastAPI · Solana":        "lucide:coins",
  "ETL · AWS Lambda":        "lucide:database",
  "Computer vision · QC":    "lucide:scan-eye",
};

const accentForId: Record<string, { bg: string; ring: string; text: string; topbar: string; hover: string }> = {
  "01": { bg: "bg-indigo-soft",  ring: "ring-indigo/30",  text: "text-indigo",      topbar: "bg-gradient-to-r from-indigo to-violet",  hover: "hover:border-indigo/50" },
  "02": { bg: "bg-magenta-soft", ring: "ring-magenta/30", text: "text-magenta",     topbar: "bg-gradient-to-r from-magenta to-coral",  hover: "hover:border-magenta/50" },
  "03": { bg: "bg-cyan-soft",    ring: "ring-cyan/30",    text: "text-cyan-deep",   topbar: "bg-gradient-to-r from-cyan to-violet",    hover: "hover:border-cyan/50" },
  "04": { bg: "bg-coral-soft",   ring: "ring-coral/30",   text: "text-coral-deep",  topbar: "bg-gradient-to-r from-coral to-amber",    hover: "hover:border-coral/50" },
};
---
<section id="work">
  <SectionHeader number={work.number} label={work.label} heading={work.heading} intro={work.intro} accent="magenta" />
  <div class="max-w-container mx-auto px-5 lg:px-10 pb-12 stagger grid md:grid-cols-2 gap-5">
    {work.items.map((item) => {
      const a = accentForId[item.id];
      return (
        <article class={`fade-up card rounded-2xl overflow-hidden group flex flex-col ${a.hover}`}>
          <div class={`h-1.5 w-full ${a.topbar}`}></div>
          <div class="p-5 lg:p-7 flex flex-col flex-1">
            <div class="flex items-start justify-between gap-3">
              <span class={`inline-flex items-center justify-center h-12 w-12 rounded-xl ${a.bg} ring-1 ${a.ring} transition-transform duration-300 group-hover:scale-110 group-hover:rotate-3`}>
                <Icon name={iconForKicker[item.kicker] || "lucide:code"} class={`w-6 h-6 ${a.text}`} />
              </span>
              <span class={`font-mono text-[11px] font-bold ${a.text}`}>{item.id}</span>
            </div>
            <p class={`mt-4 font-mono text-[11px] uppercase tracking-wider ${a.text} font-semibold`}>
              {item.kicker}
            </p>
            <h3 class="mt-1 font-serif text-2xl text-ink leading-tight">{item.title}</h3>
            <p class="mt-3 text-ink-800 leading-relaxed text-sm">{item.summary}</p>
            <div class="mt-4 flex flex-wrap gap-1.5">
              {item.stack.slice(0, 5).map((s) => (
                <span class="font-mono text-[10px] px-2 py-0.5 rounded-full bg-canvas-deep text-ink-700 border border-canvas-rule">
                  {s}
                </span>
              ))}
            </div>
            <div class="mt-auto pt-5 border-t border-canvas-rule flex items-center justify-between">
              <a href={item.links.repo} class={`inline-flex items-center gap-1.5 text-sm ${a.text} font-semibold group-hover:gap-2 transition-all`}>
                View repo
                <Icon name="lucide:arrow-up-right" class="w-4 h-4" />
              </a>
              <Icon name="lucide:github" class="w-4 h-4 text-ink-400" />
            </div>
          </div>
        </article>
      );
    })}
  </div>
  <div class="max-w-container mx-auto px-5 lg:px-10 pb-16 lg:pb-24 fade-up">
    <a href={work.more.href} class="inline-flex items-center gap-2 text-sm text-ink-700 hover:text-indigo underline underline-offset-4 decoration-canvas-rule2 hover:decoration-indigo">
      {work.more.label}
      <Icon name="lucide:arrow-up-right" class="w-4 h-4" />
    </a>
  </div>
</section>
