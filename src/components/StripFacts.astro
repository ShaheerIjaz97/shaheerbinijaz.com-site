---
import { stripFacts } from "../content/site";
---
<section class="border-b border-canvas-rule">
  <div class="max-w-container mx-auto px-6 lg:px-10 py-6 grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-x-8 gap-y-4">
    {stripFacts.map((f) => (
      <div class="flex flex-col reveal">
        <span class="font-mono text-[10px] uppercase tracking-wider text-ink-400">{f.key}</span>
        <span class="text-sm text-ink mt-1">{f.value}</span>
      </div>
    ))}
  </div>
</section>
