---
import { profile, nav } from "../content/site";
---
<header class="sticky top-0 z-40 backdrop-blur-sm bg-canvas/85 border-b border-canvas-rule no-print">
  <div class="max-w-container mx-auto px-6 lg:px-10 h-14 flex items-center justify-between">
    <a href="#top" class="font-serif text-lg tracking-tight">
      {profile.name}
    </a>
    <nav class="hidden md:flex items-center gap-7">
      {nav.map((item) => (
        <a
          href={item.href}
          class="group flex items-baseline gap-1.5 text-sm text-ink-500 hover:text-ink transition-colors"
        >
          <span class="font-mono text-[10px] text-ink-300 group-hover:text-indigo">{item.num}</span>
          <span>{item.label}</span>
        </a>
      ))}
    </nav>
    <a
      href={profile.cvPath}
      class="font-mono text-xs px-3 py-1.5 border border-canvas-rule2 rounded-full hover:border-ink transition-colors"
    >
      CV
    </a>
  </div>
</header>
