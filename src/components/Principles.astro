---
import { principles } from "../content/site";
import SectionHeader from "./SectionHeader.astro";
---
<section id="principles" class="bg-canvas-deep border-y border-canvas-rule">
  <SectionHeader number={principles.number} label={principles.label} heading={principles.heading} />
  <div class="max-w-container mx-auto px-6 lg:px-10 pb-24 grid md:grid-cols-2 gap-x-10 gap-y-12">
    {principles.items.map((p, idx) => (
      <article class="reveal max-w-prose">
        <div class="flex items-baseline gap-3">
          <span class="font-mono text-xs text-indigo">{String(idx + 1).padStart(2, "0")}</span>
          <h3 class="font-serif text-2xl text-ink leading-tight">{p.title}</h3>
        </div>
        <p class="mt-3 text-ink-700 leading-relaxed pl-9">{p.body}</p>
      </article>
    ))}
  </div>
</section>
