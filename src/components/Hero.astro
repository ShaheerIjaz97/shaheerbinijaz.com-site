---
import { hero, profile } from "../content/site";
import { Icon } from "astro-icon/components";

const positionClasses: Record<string, string> = {
  "top-left":     "absolute -top-4 -left-6 md:-left-10 lg:-left-6 anim-float",
  "top-right":    "absolute -top-2 -right-6 md:-right-10 anim-float-delay",
  "bottom-left":  "absolute bottom-10 -left-8 md:-left-12 lg:-left-4 anim-float-slow",
  "bottom-right": "absolute -bottom-2 -right-6 md:-right-12 anim-float",
};

const badgeIcons: Record<string, string> = {
  "Backend":  "lucide:server",
  "Data":     "lucide:database",
  "ML & CV":  "lucide:brain-circuit",
  "Web3":     "lucide:coins",
};
---
<section id="top" class="relative overflow-hidden border-b border-canvas-rule">

  <!-- Background decorations -->
  <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-20">
    <div class="absolute top-20 right-[20%] h-[420px] w-[420px] rounded-full opacity-50"
         style="background: radial-gradient(50% 50% at 50% 50%, rgba(58,69,211,0.18), transparent 70%);"></div>
    <div class="absolute top-40 right-[5%] h-[240px] w-[240px] rounded-full opacity-40"
         style="background: radial-gradient(50% 50% at 50% 50%, rgba(232,163,60,0.20), transparent 70%);"></div>
  </div>

  <div class="max-w-container mx-auto px-6 lg:px-10 pt-16 pb-20 lg:pt-24 lg:pb-28 grid lg:grid-cols-12 gap-10 lg:gap-12 items-center">

    <!-- Left: text -->
    <div class="lg:col-span-7 order-2 lg:order-1">

      <!-- Status pill -->
      <div class="fade-up">
        <span class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full bg-moss-soft border border-moss/30">
          <span class="relative inline-flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full rounded-full bg-moss opacity-60 animate-ping"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-moss"></span>
          </span>
          <span class="font-mono text-[11px] uppercase tracking-wider text-moss font-semibold">
            {hero.status.pill}
          </span>
        </span>
      </div>

      <!-- Greeting -->
      <p class="mt-8 font-serif italic text-2xl text-ink-800 fade-up stagger-1">
        {hero.greeting}
      </p>

      <!-- Big name -->
      <h1 class="mt-1 font-sans font-extrabold tracking-tight text-display-2xl text-ink leading-[0.92] fade-up stagger-2">
        {hero.nameLines.map((line) => <span class="block">{line}</span>)}
      </h1>

      <!-- Role + italic tag -->
      <div class="mt-6 fade-up stagger-3">
        <p class="font-mono text-xs uppercase tracking-[0.18em] text-indigo font-semibold">
          {hero.roleLine}
        </p>
        <p class="mt-2 font-serif italic text-2xl text-ink-800 max-w-[28ch]">
          {hero.italicTag}.
        </p>
      </div>

      <!-- Subhead (trimmed) -->
      <p class="mt-6 max-w-prose text-base lg:text-lg text-ink-800 leading-relaxed fade-up stagger-4">
        Six years of Python backends, ETL pipelines, and ML/CV systems built to run in production from day one. Django and FastAPI on the request path. AWS Lambda and Postgres on the data side. PyTorch and YOLO when the problem is visual.
      </p>

      <!-- CTAs -->
      <div class="mt-8 flex flex-wrap items-center gap-3 fade-up stagger-5">
        <a href={hero.ctas.primary.href} class="btn btn-primary">
          {hero.ctas.primary.label}
          <Icon name="lucide:arrow-right" class="w-4 h-4" />
        </a>
        <a href={hero.ctas.secondary.href} class="btn btn-ghost">
          <Icon name="lucide:download" class="w-4 h-4" />
          {hero.ctas.secondary.label}
        </a>
      </div>

      <!-- Social row -->
      <div class="mt-6 flex flex-wrap items-center gap-x-5 gap-y-2 text-sm text-ink-700 fade-up stagger-6">
        <a href={hero.social[0].href} class="inline-flex items-center gap-1.5 hover:text-indigo underline underline-offset-4 decoration-canvas-rule2 hover:decoration-indigo">
          <Icon name="lucide:github" class="w-4 h-4" />
          GitHub
        </a>
        <a href={hero.social[1].href} class="inline-flex items-center gap-1.5 hover:text-indigo underline underline-offset-4 decoration-canvas-rule2 hover:decoration-indigo">
          <Icon name="lucide:linkedin" class="w-4 h-4" />
          LinkedIn
        </a>
        <a href={hero.social[2].href} class="inline-flex items-center gap-1.5 hover:text-indigo underline underline-offset-4 decoration-canvas-rule2 hover:decoration-indigo">
          <Icon name="lucide:mail" class="w-4 h-4" />
          Email
        </a>
        <span class="mx-1 hidden md:inline h-3 w-px bg-canvas-rule2"></span>
        <span class="font-mono text-xs text-ink-700 inline-flex items-center gap-1">
          <Icon name="lucide:map-pin" class="w-3 h-3 text-amber" />
          {profile.location}
        </span>
      </div>

    </div>

    <!-- Right: photo + floating badges -->
    <div class="lg:col-span-5 order-1 lg:order-2 scale-in">
      <div class="relative mx-auto w-full max-w-[420px] aspect-[3/4]" data-hero-photo>

        <!-- Rotated decorative cards behind photo -->
        <div aria-hidden="true"
             class="absolute inset-0 -z-10 rounded-3xl bg-amber-soft border border-amber/20"
             style="transform: rotate(-4deg) translate(-12px, 16px);">
        </div>
        <div aria-hidden="true"
             class="absolute inset-0 -z-10 rounded-3xl bg-indigo-soft border border-indigo/15"
             style="transform: rotate(3deg) translate(8px, -10px);">
        </div>

        <!-- Photo card -->
        <div class="absolute inset-0 rounded-3xl overflow-hidden bg-canvas-deep border border-canvas-rule shadow-[0_30px_60px_-30px_rgba(14,17,22,0.35)]">
          <img
            src="/shaheer.jpg"
            alt={`${profile.name} — ${profile.title}`}
            class="w-full h-full object-cover"
            loading="eager"
            decoding="async"
          />
        </div>

        <!-- Floating expertise badges (now with icons + float animation) -->
        {hero.badges.map((b) => (
          <div class={`${positionClasses[b.position]} hidden md:block`}>
            <div class="card rounded-2xl px-4 py-3 bg-canvas shadow-[0_12px_32px_-12px_rgba(14,17,22,0.25)] min-w-[160px]">
              <div class="flex items-center gap-2">
                <Icon name={badgeIcons[b.kicker] || "lucide:code"} class="w-3.5 h-3.5 text-indigo" />
                <p class="font-mono text-[10px] uppercase tracking-wider text-indigo font-semibold">{b.kicker}</p>
              </div>
              <p class="mt-1 text-sm text-ink font-medium">{b.label}</p>
            </div>
          </div>
        ))}

      </div>
    </div>

  </div>
</section>
