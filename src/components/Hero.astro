---
import { hero, profile } from "../content/site";
import { Icon } from "astro-icon/components";

const positionClasses: Record<string, string> = {
  "top-left":     "absolute -top-4 -left-6 md:-left-10 lg:-left-6 anim-float",
  "top-right":    "absolute -top-2 -right-6 md:-right-10 anim-float-delay",
  "bottom-left":  "absolute bottom-10 -left-8 md:-left-12 lg:-left-4 anim-float-slow",
  "bottom-right": "absolute -bottom-2 -right-6 md:-right-12 anim-float",
};

const badgeIcons: Record<string, string> = {
  "Backend":  "lucide:server",
  "Data":     "lucide:database",
  "ML & CV":  "lucide:brain-circuit",
  "Web3":     "lucide:coins",
};
---
<section id="top" class="relative isolate overflow-hidden border-b border-canvas-rule">

  <!-- Vivid gradient mesh background — visible but not screaming over text -->
  <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-20 overflow-hidden">
    <!-- Magenta blob top-left -->
    <div class="absolute -top-32 -left-24 h-[640px] w-[640px] rounded-full"
         style="background: radial-gradient(closest-side, rgba(224,52,139,0.55), rgba(224,52,139,0) 70%);"></div>
    <!-- Violet blob top-right -->
    <div class="absolute -top-10 -right-10 h-[680px] w-[680px] rounded-full"
         style="background: radial-gradient(closest-side, rgba(124,58,237,0.50), rgba(124,58,237,0) 70%);"></div>
    <!-- Cyan blob center -->
    <div class="absolute top-[40%] left-[30%] h-[520px] w-[520px] rounded-full"
         style="background: radial-gradient(closest-side, rgba(14,165,200,0.45), rgba(14,165,200,0) 70%);"></div>
    <!-- Coral blob bottom-right -->
    <div class="absolute -bottom-10 right-[15%] h-[460px] w-[460px] rounded-full"
         style="background: radial-gradient(closest-side, rgba(255,107,71,0.42), rgba(255,107,71,0) 70%);"></div>
    <!-- Lime blob bottom-left -->
    <div class="absolute -bottom-32 -left-10 h-[420px] w-[420px] rounded-full"
         style="background: radial-gradient(closest-side, rgba(163,230,53,0.35), rgba(163,230,53,0) 70%);"></div>
    <!-- Subtle grid texture overlay -->
    <div class="absolute inset-0 bg-grid bg-grid opacity-[0.25]"></div>
  </div>
  <!-- Bottom chromatic stripe bleeds into next section -->
  <div aria-hidden="true" class="pointer-events-none absolute inset-x-0 bottom-0 h-1.5 bg-gradient-to-r from-magenta via-violet via-cyan to-coral z-10"></div>

  <div class="max-w-container mx-auto px-5 lg:px-10 pt-10 pb-14 lg:pt-24 lg:pb-28 grid lg:grid-cols-12 gap-8 lg:gap-12 items-center">

    <!-- Left: text — appears first on mobile too -->
    <div class="lg:col-span-7 order-1">

      <!-- Status pill — gradient border with live ping dot -->
      <div class="fade-up">
        <span class="relative inline-flex items-center gap-2 px-4 py-2 rounded-full bg-canvas shadow-md ring-2 ring-transparent"
              style="background-image: linear-gradient(theme(colors.canvas.DEFAULT), theme(colors.canvas.DEFAULT)), linear-gradient(90deg, theme(colors.lime.DEFAULT), theme(colors.cyan.DEFAULT), theme(colors.violet.DEFAULT)); background-origin: border-box; background-clip: padding-box, border-box; border: 2px solid transparent;">
          <span class="relative inline-flex h-2.5 w-2.5">
            <span class="absolute inline-flex h-full w-full rounded-full bg-lime opacity-80 animate-ping"></span>
            <span class="relative inline-flex h-2.5 w-2.5 rounded-full bg-lime-deep"></span>
          </span>
          <span class="font-mono text-[11px] uppercase tracking-[0.16em] text-ink font-bold">
            {hero.status.pill}
          </span>
        </span>
      </div>

      <!-- Greeting -->
      <p class="mt-6 lg:mt-8 font-serif italic text-xl lg:text-2xl text-ink-800 fade-up stagger-1">
        {hero.greeting}
      </p>

      <!-- Big name — last line gets vivid magenta→violet→cyan gradient -->
      <h1 class="mt-1 font-sans font-extrabold tracking-tight text-[2.625rem] sm:text-[3.5rem] lg:text-display-2xl text-ink leading-[0.95] lg:leading-[0.92] fade-up stagger-2">
        {hero.nameLines.map((line, i) => (
          <span class={`block ${i === hero.nameLines.length - 1 ? "bg-gradient-to-r from-magenta via-violet to-cyan bg-clip-text text-transparent" : ""}`}>{line}</span>
        ))}
      </h1>

      <!-- Role + italic tag -->
      <div class="mt-6 fade-up stagger-3">
        <p class="font-mono text-xs uppercase tracking-[0.18em] text-violet font-semibold">
          {hero.roleLine}
        </p>
        <p class="mt-2 font-serif italic text-2xl text-ink-800 max-w-[28ch]">
          {hero.italicTag}.
        </p>
      </div>

      <!-- Subhead (trimmed) -->
      <p class="mt-6 max-w-prose text-base lg:text-lg text-ink-800 leading-relaxed fade-up stagger-4">
        Six years of Python backends, ETL pipelines, and ML/CV systems built to run in production from day one. Django and FastAPI on the request path. AWS Lambda and Postgres on the data side. PyTorch and YOLO when the problem is visual.
      </p>

      <!-- CTAs -->
      <div class="mt-7 lg:mt-8 grid grid-cols-1 sm:flex sm:flex-wrap items-stretch sm:items-center gap-3 fade-up stagger-5">
        <a href={hero.ctas.primary.href} class="btn btn-primary justify-center sm:justify-start">
          {hero.ctas.primary.label}
          <Icon name="lucide:arrow-right" class="w-4 h-4" />
        </a>
        <a href={hero.ctas.secondary.href} class="btn btn-ghost justify-center sm:justify-start">
          <Icon name="lucide:download" class="w-4 h-4" />
          {hero.ctas.secondary.label}
        </a>
      </div>

      <!-- Social row -->
      <div class="mt-6 flex flex-wrap items-center gap-x-5 gap-y-2 text-sm text-ink-700 fade-up stagger-6">
        <a href={hero.social[0].href} class="inline-flex items-center gap-1.5 hover:text-indigo underline underline-offset-4 decoration-canvas-rule2 hover:decoration-indigo">
          <Icon name="lucide:github" class="w-4 h-4" />
          GitHub
        </a>
        <a href={hero.social[1].href} class="inline-flex items-center gap-1.5 hover:text-indigo underline underline-offset-4 decoration-canvas-rule2 hover:decoration-indigo">
          <Icon name="lucide:linkedin" class="w-4 h-4" />
          LinkedIn
        </a>
        <a href={hero.social[2].href} class="inline-flex items-center gap-1.5 hover:text-indigo underline underline-offset-4 decoration-canvas-rule2 hover:decoration-indigo">
          <Icon name="lucide:mail" class="w-4 h-4" />
          Email
        </a>
        <span class="mx-1 hidden md:inline h-3 w-px bg-canvas-rule2"></span>
        <span class="font-mono text-xs text-ink-700 inline-flex items-center gap-1">
          <Icon name="lucide:map-pin" class="w-3 h-3 text-amber" />
          {profile.location}
        </span>
      </div>

    </div>

    <!-- Right: photo + floating badges — comes after text on mobile, side on desktop -->
    <div class="lg:col-span-5 order-2 scale-in">
      <div class="relative mx-auto w-full max-w-[280px] sm:max-w-[340px] lg:max-w-[420px] aspect-[3/4]" data-hero-photo>

        <!-- Rotated decorative cards behind photo — hidden on smallest screens to reduce noise -->
        <div aria-hidden="true"
             class="hidden sm:block absolute inset-0 -z-10 rounded-3xl bg-magenta-soft border border-magenta/30"
             style="transform: rotate(-5deg) translate(-14px, 18px);">
        </div>
        <div aria-hidden="true"
             class="hidden sm:block absolute inset-0 -z-10 rounded-3xl bg-cyan-soft border border-cyan/30"
             style="transform: rotate(4deg) translate(10px, -12px);">
        </div>

        <!-- Photo with vivid gradient frame: magenta → violet → cyan -->
        <div class="absolute inset-0 rounded-3xl p-[3px] bg-gradient-to-br from-magenta via-violet to-cyan shadow-[0_30px_60px_-20px_rgba(124,58,237,0.55)]">
          <div class="relative w-full h-full rounded-[22px] overflow-hidden bg-canvas-deep">
            <img
              src="/shaheer.jpg"
              alt={`${profile.name} — ${profile.title}`}
              class="w-full h-full object-cover"
              loading="eager"
              decoding="async"
            />
            <!-- Subtle bottom glow scrim -->
            <div aria-hidden="true" class="absolute inset-x-0 bottom-0 h-24 bg-gradient-to-t from-violet/25 to-transparent"></div>
          </div>
        </div>

        <!-- Floating expertise badges — each gets its own bold accent color -->
        {hero.badges.map((b, idx) => {
          const badgeAccents = [
            { text: "text-magenta", chip: "bg-magenta-soft" },
            { text: "text-cyan",    chip: "bg-cyan-soft" },
            { text: "text-violet",  chip: "bg-violet-soft" },
            { text: "text-coral",   chip: "bg-coral-soft" },
          ];
          const a = badgeAccents[idx % 4];
          return (
            <div class={`${positionClasses[b.position]} hidden md:block`}>
              <div class="rounded-2xl px-4 py-3 bg-canvas border border-canvas-rule shadow-[0_18px_40px_-12px_rgba(14,17,22,0.30)] min-w-[160px] hover:-translate-y-1 transition-transform">
                <div class="flex items-center gap-2">
                  <span class={`inline-flex items-center justify-center w-6 h-6 rounded-md ${a.chip}`}>
                    <Icon name={badgeIcons[b.kicker] || "lucide:code"} class={`w-3.5 h-3.5 ${a.text}`} />
                  </span>
                  <p class={`font-mono text-[10px] uppercase tracking-wider ${a.text} font-semibold`}>{b.kicker}</p>
                </div>
                <p class="mt-1 text-sm text-ink font-medium">{b.label}</p>
              </div>
            </div>
          );
        })}

      </div>
    </div>

  </div>
</section>
