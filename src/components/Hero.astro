---
import { hero, profile } from "../content/site";

const positionClasses: Record<string, string> = {
  "top-left":     "absolute -top-4 -left-6 md:-left-10 lg:-left-6",
  "top-right":    "absolute -top-2 -right-6 md:-right-10",
  "bottom-left":  "absolute bottom-10 -left-8 md:-left-12 lg:-left-4",
  "bottom-right": "absolute -bottom-2 -right-6 md:-right-12",
};
---
<section id="top" class="relative overflow-hidden border-b border-canvas-rule">
  <!-- Soft background halo -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 -z-10 opacity-60"
    style="background: radial-gradient(60% 50% at 75% 35%, rgba(58,69,211,0.10), transparent 70%);">
  </div>

  <div class="max-w-container mx-auto px-6 lg:px-10 pt-16 pb-20 lg:pt-24 lg:pb-28 grid lg:grid-cols-12 gap-10 lg:gap-12 items-center">

    <!-- Left: text -->
    <div class="lg:col-span-7 order-2 lg:order-1">

      <!-- Status pill -->
      <div class="flex items-center gap-2 reveal">
        {hero.status.dot && (
          <span class="relative inline-flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full rounded-full bg-indigo opacity-60 animate-ping"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-indigo"></span>
          </span>
        )}
        <span class="font-mono text-[11px] uppercase tracking-wider text-ink-500">
          {hero.status.pill}
        </span>
      </div>

      <!-- Greeting -->
      <p class="mt-8 font-serif italic text-2xl text-ink-700 reveal">
        {hero.greeting}
      </p>

      <!-- Big name -->
      <h1 class="mt-1 font-sans font-extrabold tracking-tight text-display-2xl text-ink leading-[0.92] reveal">
        {hero.nameLines.map((line, i) => (
          <span class="block">{line}</span>
        ))}
      </h1>

      <!-- Role + italic tag -->
      <div class="mt-6 reveal">
        <p class="font-mono text-xs uppercase tracking-[0.18em] text-indigo">
          {hero.roleLine}
        </p>
        <p class="mt-2 font-serif italic text-2xl text-ink-700 max-w-[28ch]">
          {hero.italicTag}.
        </p>
      </div>

      <!-- Subhead -->
      <p class="mt-6 max-w-prose text-base lg:text-lg text-ink-700 leading-relaxed reveal">
        {hero.subhead}
      </p>

      <!-- CTAs -->
      <div class="mt-8 flex flex-wrap items-center gap-3 reveal">
        <a href={hero.ctas.primary.href} class="btn btn-primary">
          {hero.ctas.primary.label}
          <span aria-hidden="true">→</span>
        </a>
        <a href={hero.ctas.secondary.href} class="btn btn-ghost">
          {hero.ctas.secondary.label}
        </a>
      </div>

      <!-- Social row -->
      <div class="mt-6 flex flex-wrap items-center gap-x-5 gap-y-2 text-sm text-ink-500 reveal">
        {hero.social.map((s) => (
          <a href={s.href} class="hover:text-ink underline underline-offset-4 decoration-canvas-rule2 hover:decoration-ink">
            {s.label}
            <span class="ml-0.5 opacity-60" aria-hidden="true">↗</span>
          </a>
        ))}
        <span class="mx-1 hidden md:inline h-3 w-px bg-canvas-rule2"></span>
        <span class="font-mono text-xs text-ink-400">{profile.location}</span>
      </div>

    </div>

    <!-- Right: photo + floating badges -->
    <div class="lg:col-span-5 order-1 lg:order-2 reveal">
      <div class="relative mx-auto w-full max-w-[420px] aspect-[3/4]">

        <!-- Halo gradient behind photo -->
        <div
          aria-hidden="true"
          class="absolute inset-[-12%] rounded-full -z-10"
          style="background: radial-gradient(50% 50% at 50% 45%, rgba(58,69,211,0.18), transparent 70%);">
        </div>

        <!-- Photo card -->
        <div class="absolute inset-0 rounded-3xl overflow-hidden bg-canvas-deep border border-canvas-rule shadow-[0_30px_60px_-30px_rgba(14,17,22,0.30)]">
          <img
            src="/shaheer.jpg"
            alt={`${profile.name} — ${profile.title}`}
            class="w-full h-full object-cover"
            loading="eager"
            decoding="async"
          />
        </div>

        <!-- Floating expertise badges -->
        {hero.badges.map((b) => (
          <div class={`${positionClasses[b.position]} hidden md:block`}>
            <div class="card rounded-2xl px-4 py-3 bg-canvas shadow-[0_12px_32px_-12px_rgba(14,17,22,0.25)] min-w-[160px]">
              <p class="font-mono text-[10px] uppercase tracking-wider text-indigo">{b.kicker}</p>
              <p class="mt-1 text-sm text-ink font-medium">{b.label}</p>
            </div>
          </div>
        ))}

      </div>
    </div>

  </div>
</section>
