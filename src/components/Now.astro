---
import { now } from "../content/site";
import SectionHeader from "./SectionHeader.astro";
import { Icon } from "astro-icon/components";

const icons = [
  "lucide:hospital",      // Kenya healthcare
  "lucide:flask-conical", // ML lifecycle
  "lucide:layers",        // Solana indexing
  "lucide:zap",           // performance
];
---
<section id="now" class="bg-canvas-deep border-y border-canvas-rule">
  <SectionHeader number={now.number} label={now.label} heading={now.heading} accent="amber" />
  <div class="max-w-container mx-auto px-6 lg:px-10 pb-24 stagger grid md:grid-cols-2 gap-5">
    {now.items.map((line, idx) => (
      <div class="fade-up card rounded-xl p-5 flex items-start gap-4">
        <span class="inline-flex items-center justify-center h-11 w-11 rounded-lg bg-amber-soft text-amber-deep flex-shrink-0">
          <Icon name={icons[idx] || "lucide:circle"} class="w-5 h-5" />
        </span>
        <p class="text-ink-800 leading-relaxed text-sm pt-1.5">{line}</p>
      </div>
    ))}
  </div>
</section>
