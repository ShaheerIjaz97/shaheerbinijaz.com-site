---
import { experience } from "../content/site";
import SectionHeader from "./SectionHeader.astro";
import { Icon } from "astro-icon/components";
---
<section id="experience">
  <SectionHeader number={experience.number} label={experience.label} heading={experience.heading} accent="amber" />
  <div class="max-w-container mx-auto px-6 lg:px-10 pb-24">
    <ol class="relative stagger space-y-10 pl-6 md:pl-8 border-l-2 border-canvas-rule2">
      {experience.items.map((item, idx) => (
        <li class="fade-right relative">
          <!-- Timeline dot -->
          <span class="absolute -left-[33px] md:-left-[41px] top-1.5 inline-flex items-center justify-center h-6 w-6 rounded-full bg-canvas border-2 border-indigo shadow-[0_2px_8px_-2px_rgba(58,69,211,0.45)]">
            <span class="h-1.5 w-1.5 rounded-full bg-indigo"></span>
          </span>
          <div class="grid lg:grid-cols-12 gap-4 lg:gap-10">
            <div class="lg:col-span-3">
              <div class="inline-flex items-center gap-1.5 font-mono text-[11px] text-ink-700 bg-canvas-deep px-2 py-1 rounded-full border border-canvas-rule">
                <Icon name="lucide:calendar" class="w-3 h-3 text-amber" />
                {item.period}
              </div>
              <p class="mt-2 font-mono text-[10px] text-ink-400 inline-flex items-center gap-1">
                <Icon name="lucide:map-pin" class="w-3 h-3" />
                {item.location}
              </p>
            </div>
            <div class="lg:col-span-9 max-w-prose">
              <h3 class="font-serif text-2xl text-ink leading-tight">{item.role}</h3>
              <p class="mt-1 text-sm text-indigo font-semibold inline-flex items-center gap-1.5">
                <Icon name="lucide:building-2" class="w-4 h-4" />
                {item.org}
              </p>
              <ul class="mt-4 space-y-2.5">
                {item.bullets.map((b: string) => (
                  <li class="flex gap-3 text-ink-800 leading-relaxed text-sm">
                    <Icon name="lucide:check" class="w-4 h-4 mt-1 text-moss flex-shrink-0" />
                    <span>{b}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>
