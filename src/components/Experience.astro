---
import { experience } from "../content/site";
import SectionHeader from "./SectionHeader.astro";
---
<section id="experience" class="bg-canvas-deep border-y border-canvas-rule">
  <SectionHeader number={experience.number} label={experience.label} heading={experience.heading} />
  <div class="max-w-container mx-auto px-6 lg:px-10 pb-24">
    <ol class="space-y-12">
      {experience.items.map((item, idx) => (
        <li class="reveal grid lg:grid-cols-12 gap-4 lg:gap-10">
          <div class="lg:col-span-3 flex flex-col gap-1">
            <span class="font-mono text-xs text-indigo">{String(idx + 1).padStart(2, "0")}</span>
            <span class="font-mono text-xs text-ink-500">{item.period}</span>
            <span class="font-mono text-[10px] text-ink-400 mt-0.5">{item.location}</span>
          </div>
          <div class="lg:col-span-9 max-w-prose">
            <h3 class="font-serif text-2xl text-ink leading-tight">{item.role}</h3>
            <p class="mt-1 text-sm text-ink-500">{item.org}</p>
            <ul class="mt-4 space-y-2.5">
              {item.bullets.map((b: string) => (
                <li class="flex gap-3 text-ink-700 leading-relaxed">
                  <span class="mt-2 h-1 w-1.5 bg-indigo flex-shrink-0 rounded-full"></span>
                  <span>{b}</span>
                </li>
              ))}
            </ul>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>
