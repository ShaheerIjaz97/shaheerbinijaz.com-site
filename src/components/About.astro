---
import { about } from "../content/site";
import SectionHeader from "./SectionHeader.astro";
---
<section id="about">
  <SectionHeader number={about.number} label={about.label} heading={about.heading} />
  <div class="max-w-container mx-auto px-6 lg:px-10 pb-24 grid lg:grid-cols-12 gap-10">
    <div class="lg:col-span-8 space-y-6 max-w-prose reveal">
      {about.paragraphs.map((p) => (
        <p class="text-ink-700 leading-relaxed">{p}</p>
      ))}
    </div>
    <aside class="lg:col-span-4 reveal">
      <ul class="space-y-3">
        {about.bullets.map((b) => (
          <li class="flex gap-3 text-sm text-ink-700">
            <span class="mt-1.5 h-1 w-1 rounded-full bg-indigo flex-shrink-0"></span>
            <span>{b}</span>
          </li>
        ))}
      </ul>
    </aside>
  </div>
</section>
