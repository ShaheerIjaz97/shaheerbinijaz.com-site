---
import { stack } from "../content/site";
import SectionHeader from "./SectionHeader.astro";
import { Icon } from "astro-icon/components";

const groupIcon: Record<string, string> = {
  "Languages":     "lucide:code-2",
  "Backend":       "lucide:server",
  "Data":          "lucide:database",
  "ML / CV":       "lucide:brain-circuit",
  "Cloud & infra": "lucide:cloud",
  "Event-driven":  "lucide:network",
  "Blockchain":    "lucide:coins",
  "Observability": "lucide:line-chart",
};
const groupAccent: Record<string, string> = {
  "Languages":     "text-indigo bg-indigo-soft",
  "Backend":       "text-indigo bg-indigo-soft",
  "Data":          "text-amber-deep bg-amber-soft",
  "ML / CV":       "text-moss bg-moss-soft",
  "Cloud & infra": "text-indigo bg-indigo-soft",
  "Event-driven":  "text-amber-deep bg-amber-soft",
  "Blockchain":    "text-amber-deep bg-amber-soft",
  "Observability": "text-moss bg-moss-soft",
};
---
<section id="stack" class="bg-canvas-deep border-y border-canvas-rule">
  <SectionHeader number={stack.number} label={stack.label} heading={stack.heading} accent="indigo" />
  <div class="max-w-container mx-auto px-6 lg:px-10 pb-24 stagger grid md:grid-cols-2 lg:grid-cols-4 gap-5">
    {stack.groups.map((g) => (
      <div class="fade-up card rounded-xl p-5">
        <div class="flex items-center gap-2">
          <span class={`inline-flex items-center justify-center h-9 w-9 rounded-lg ${groupAccent[g.title] || "text-indigo bg-indigo-soft"}`}>
            <Icon name={groupIcon[g.title] || "lucide:code"} class="w-5 h-5" />
          </span>
          <h3 class="font-mono text-xs uppercase tracking-wider text-ink-800 font-semibold">{g.title}</h3>
        </div>
        <div class="mt-3 flex flex-wrap gap-1.5">
          {g.items.map((item) => (
            <span class="chip text-xs">{item}</span>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>
