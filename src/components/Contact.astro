---
import { contact } from "../content/site";
import { Icon } from "astro-icon/components";

const channelIcons: Record<string, string> = {
  "shaheer.ijaz03@gmail.com": "lucide:mail",
  "LinkedIn DM":               "lucide:linkedin",
  "GitHub":                    "lucide:github",
};
---
<section id="contact" class="relative bg-ink text-canvas overflow-hidden">

  <!-- Decorative orbs -->
  <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-0">
    <div class="absolute -top-20 -right-20 h-[500px] w-[500px] rounded-full opacity-30"
         style="background: radial-gradient(50% 50% at 50% 50%, rgba(58,69,211,0.55), transparent 70%);"></div>
    <div class="absolute -bottom-32 left-[10%] h-[400px] w-[400px] rounded-full opacity-25"
         style="background: radial-gradient(50% 50% at 50% 50%, rgba(232,163,60,0.55), transparent 70%);"></div>
  </div>

  <div class="relative max-w-container mx-auto px-6 lg:px-10 pt-24 pb-24 lg:pt-28 lg:pb-28">

    <header class="fade-up">
      <div class="flex items-center gap-4">
        <span class="inline-flex items-center justify-center h-7 px-2.5 rounded-full font-mono text-[11px] font-bold bg-amber text-ink">
          {contact.number}
        </span>
        <span class="font-mono text-xs uppercase tracking-[0.18em] text-amber-dim font-semibold">{contact.label}</span>
        <span class="hidden md:inline-block h-[2px] w-12 bg-amber opacity-60 rounded-full"></span>
      </div>
      <h2 class="mt-5 font-serif text-display-lg max-w-[32ch] leading-[1.05]">
        {contact.heading}
      </h2>
    </header>

    <div class="mt-12 grid lg:grid-cols-12 gap-10 items-start">
      <div class="lg:col-span-7 max-w-prose fade-up stagger-1">
        <p class="text-ink-200 leading-relaxed text-lg">{contact.body}</p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href={`mailto:${channelIcons["shaheer.ijaz03@gmail.com"] && "shaheer.ijaz03@gmail.com"}`}
             class="btn btn-amber">
            <Icon name="lucide:mail" class="w-4 h-4" />
            Email me
          </a>
          <a href="https://www.linkedin.com/in/shaheer-bin-ijaz/"
             class="btn !bg-canvas !text-ink hover:!bg-indigo hover:!text-canvas">
            <Icon name="lucide:linkedin" class="w-4 h-4" />
            LinkedIn DM
          </a>
        </div>
      </div>

      <ul class="lg:col-span-5 stagger space-y-3">
        {contact.channels.map((c) => (
          <li class="fade-up">
            <a href={c.href} class="group flex items-center justify-between gap-3 px-4 py-3 rounded-xl border border-canvas/15 hover:border-amber/60 hover:bg-canvas/[0.03] transition-all">
              <span class="inline-flex items-center gap-3 text-canvas">
                <span class="inline-flex items-center justify-center h-9 w-9 rounded-lg bg-canvas/10 text-amber group-hover:bg-amber group-hover:text-ink transition-colors">
                  <Icon name={channelIcons[c.label] || "lucide:arrow-up-right"} class="w-4 h-4" />
                </span>
                <span class="text-base">{c.label}</span>
              </span>
              <Icon name="lucide:arrow-up-right" class="w-4 h-4 text-canvas/50 group-hover:text-amber transition-colors" />
            </a>
          </li>
        ))}
      </ul>
    </div>

  </div>
</section>
