---
import { education } from "../content/site";
import SectionHeader from "./SectionHeader.astro";
---
<section id="education">
  <SectionHeader number={education.number} label={education.label} heading={education.heading} />
  <div class="max-w-container mx-auto px-6 lg:px-10 pb-24">
    <ul class="space-y-8 max-w-prose">
      {education.items.map((item, idx) => (
        <li class="reveal grid lg:grid-cols-12 gap-3 lg:gap-10">
          <div class="lg:col-span-3 flex flex-col gap-1">
            <span class="font-mono text-xs text-indigo">{String(idx + 1).padStart(2, "0")}</span>
            <span class="font-mono text-xs text-ink-500">{item.period}</span>
          </div>
          <div class="lg:col-span-9">
            <p class="font-serif text-xl text-ink">{item.degree}</p>
            <p class="mt-1 text-sm text-ink-500">{item.org}</p>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>
